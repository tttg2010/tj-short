# Copy to .env locally. Never commit real keys.
# Register at https://www.salpx.com and create/copy your API Key.
# Full video generation from Codex requires SALPX_API_KEY.
SALPX_API_KEY=
SALPX_BASE_URL=https://www.salpx.com/v1

# Image generation
SALPX_IMAGE_MODEL=gpt-image-2

# Video generation
SALPX_VIDEO_MODEL=omni_flash
SALPX_OMNI_MODEL=omni_flash

# Common alternatives:
# SALPX_VIDEO_MODEL=gemini_omni_flash
# SALPX_VIDEO_MODEL=seedance-2-mini-480p
# SALPX_VIDEO_MODEL=<your-salpx-veo-model-id>
